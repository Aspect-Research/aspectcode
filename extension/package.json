{
  "name": "aspectcode-vscode",
  "private": true,
  "displayName": "Aspect Code",
  "description": "AI-powered static analysis with Tree-sitter for AI assistant integration",
  "version": "0.1.4",
  "publisher": "aspectcode",
  "license": "SEE LICENSE IN LICENSE.md",
  "preview": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/asashepard/aspectcode"
  },
  "bugs": {
    "url": "https://github.com/asashepard/aspectcode/issues"
  },
  "homepage": "https://github.com/asashepard/aspectcode#readme",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "keywords": [
    "static analysis",
    "linter",
    "code quality",
    "security",
    "bugs",
    "tree-sitter",
    "AI",
    "typescript",
    "python",
    "java",
    "csharp",
    "javascript",
    "code review"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aspectcode.toggleExtensionEnabled",
        "title": "Aspect Code: Toggle Enabled"
      },
      {
        "command": "aspectcode.generate",
        "title": "Aspect Code: Generate",
        "icon": "$(book)"
      },
      {
        "command": "aspectcode.generateKb",
        "title": "Aspect Code: Generate Knowledge Base",
        "icon": "$(database)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Aspect Code",
      "properties": {
        "aspectcode.suppressSetupPrompt": {
          "type": "boolean",
          "default": false,
          "description": "When true, Aspect Code will never prompt you to set up new repositories. Individual repos can also be dismissed from the prompt itself."
        },
        "aspectcode.devLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose extension logs for debugging"
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --outfile=dist/extension.js --external:vscode",
    "watch": "npm run watch:extension",
    "watch:extension": "esbuild src/extension.ts --bundle --platform=node --outfile=dist/extension.js --external:vscode --watch",
    "compile": "npm run build",
    "test:e2e": "mocha --require ts-node/register --ui tdd \"src/test/**/*.test.ts\"",
    "test:integration:cli-adapter": "mocha --require ts-node/register --ui tdd \"src/test/cliAdapter.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 200",
    "lint:fix": "eslint src/ --fix --max-warnings 200",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check:filesize": "node scripts/check-file-size.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:all": "npm run lint && npm run format:check && npm run check:filesize && npm run check:boundaries"
  },
  "devDependencies": {
    "@types/diff": "^5.2.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.92.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "mocha": "^10.4.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@aspectcode/core": "*",
    "@aspectcode/emitters": "*",
    "diff": "^5.2.0",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "^0.21.0",
    "yaml": "2.8.1"
  }
}
