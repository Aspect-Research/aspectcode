{
  "name": "aspectcode",
  "version": "0.3.5",
  "description": "CLI for Aspect Code — generate knowledge-base artifacts from the command line",
  "license": "MIT",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "aspectcode": "bin/aspectcode.js",
    "aspect": "bin/aspectcode.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "aspectcode",
    "knowledge-base",
    "ai",
    "copilot",
    "cursor",
    "claude",
    "code-analysis",
    "static-analysis",
    "dependency-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/asashepard/aspectcode.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs",
    "check:bundled": "node scripts/check-bundled-deps.mjs",
    "test": "mocha --require ts-node/register 'test/**/*.test.ts'"
  },
  "bundledDependencies": [
    "@aspectcode/core",
    "@aspectcode/emitters",
    "@aspectcode/evaluator",
    "@aspectcode/optimizer"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aspectcode/core": "0.3.1",
    "@aspectcode/emitters": "0.3.4",
    "@aspectcode/evaluator": "0.3.4",
    "@aspectcode/optimizer": "0.3.4",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.0",
    "ink": "3.2.0",
    "openai": "^4.70.0",
    "react": "17.0.2",
    "web-tree-sitter": "^0.21.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "17.0.91",
    "mocha": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
